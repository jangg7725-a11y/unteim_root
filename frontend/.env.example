# ── 필수 ──────────────────────────────────────────────
# Render API 서버 주소 (끝 슬래시 없음)
# Render 대시보드 unteim-web > Environment 탭에도 동일하게 입력
VITE_API_BASE_URL=https://unteim-api.onrender.com

# ── 로컬 개발 ─────────────────────────────────────────
# 로컬 백엔드 실행 시 (비우면 Vite proxy 자동 사용)
# VITE_API_BASE_URL=http://127.0.0.1:8000

# ── 프리미엄 기능 ──────────────────────────────────────
# false = 잠금 (상용 배포), true = 해제 (개발/테스트)
VITE_UNLOCK_PREMIUM=true
