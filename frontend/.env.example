# 로컬 개발: 비우면 요청이 /api/... 로 가고 Vite가 백엔드로 프록시합니다.
# VITE_API_BASE_URL=

# 배포 빌드(Render·Cloudflare Pages 등): 공개 API 베이스 URL 필수 (끝 슬래시 없음)
# VITE_API_BASE_URL=https://your-api-host.example.com

# 로컬에서 백엔드 포트를 바꿀 때만 (기본 http://127.0.0.1:8000)
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# 선택: 별도 TTS 서버가 있을 때
# VITE_TTS_API_URL=
