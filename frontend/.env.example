# 복사: copy .env.example .env  (또는 수동으로 .env 생성)
# Vite는 VITE_ 접두사만 클라이언트에 노출됩니다.

# --- REST API (배포 시 필수에 가깝게 설정) ---
# 비우면: `npm run dev`에서 `/api` → Vite proxy → 로컬 백엔드
# 배포 정적 호스팅: 백엔드 공개 URL (끝 슬래시 없음)
# 예: VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# (선택) 예전 이름 — VITE_API_BASE_URL이 있으면 무시됨
# VITE_API_BASE=

# --- 개발 전용: Vite dev 서버 프록시 대상 (기본 http://127.0.0.1:8000) ---
# VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000

# --- TTS (선택) — 서버가 POST /tts { text, voice } -> audio/mpeg 를 제공할 때만 ---
# VITE_TTS_API_URL=https://tts.example.com
