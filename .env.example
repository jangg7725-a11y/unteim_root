# 프로젝트 루트에 `.env` 로 복사해 사용 (python-dotenv가 `scripts/run_api_server_v1.py` 실행 시 로드)
# 절대 커밋하지 마세요 — `.gitignore`에 `.env` 포함 권장

# --- OpenAI (AI 상담·요약 카드) ---
OPENAI_API_KEY=
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_COUNSEL_MODEL=gpt-4o-mini
# OPENAI_SESSION_CARD_MODEL=gpt-4o-mini

# --- 백엔드 바인딩 (로컬: 127.0.0.1, VPS·Docker: 0.0.0.0) ---
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
# 프로덕션에서 자동 리로드 끄기: UVICORN_RELOAD=0
UVICORN_RELOAD=1

# --- CORS (프론트 배포 도메인, 쉼표 구분. 비우면 *) ---
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# --- 기타 (엔진에서 사용 시) ---
# KASI 등 외부 API 키는 해당 모듈 문서 참고 — 코드에 하드코딩 금지
