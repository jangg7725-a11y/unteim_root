# -*- coding: utf-8 -*-
"""
unteim.engine.sewunCalculator
- 세운(연도별) 기본 리스트만 산출하는 최소 동작 초안
"""

from typing import List, Dict

HEAVENLY_STEMS = ["갑", "을", "병", "정", "무", "기", "경", "신", "임", "계"]
EARTHLY_BRANCHES = ["자", "축", "인", "묘", "진", "사", "오", "미", "신", "유", "술", "해"]

def year_ganji(year: int) -> str:
    """
    주어진 양력 연도의 간지(연간·연지)를 1984(갑자) 기준으로 계산.
    - 1984: 갑자 (stem_idx=0, branch_idx=0)
    """
    stem = HEAVENLY_STEMS[(year - 1984) % 10]
    branch = EARTHLY_BRANCHES[(year - 1984) % 12]
    return stem + branch

def calculate_sewun(start_year: int, num_years: int = 10) -> List[Dict[str, int | str]]:
    """
    세운 리스트(년도, 간지) 생성
    - start_year부터 num_years년 만큼 연속 계산
    """
    results: List[Dict[str, int | str]] = []
    for i in range(num_years):
        y = start_year + i
        results.append({
            "year": y,
            "ganji": year_ganji(y)
        })
    return results

if __name__ == "__main__":
    # 빠른 수동 테스트용
    sample = calculate_sewun(start_year=2025, num_years=12)
    print("세운 계산 예시:", sample)
